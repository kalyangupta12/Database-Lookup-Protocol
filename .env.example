# ── Database Detection ─────────────────────────────────────────────────────────
# Set DATABASE_URL for auto-detection, OR use DB_TYPE + individual vars.

# Auto-detect examples:
# DATABASE_URL=postgresql://user:pass@localhost:5432/mydb
# DATABASE_URL=mysql://user:pass@localhost:3306/mydb
# DATABASE_URL=mongodb://user:pass@localhost:27017/mydb
# DATABASE_URL=mssql://user:pass@localhost:1433/mydb

# Explicit override (postgres | mysql | mongodb | mssql | prisma):
# DB_TYPE=postgres

# PostgreSQL (if not using DATABASE_URL):
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=mydb
PG_USER=postgres
PG_PASSWORD=secret
PG_SSL=false

# MySQL / MariaDB:
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mydb
MYSQL_USER=root
MYSQL_PASSWORD=secret

# MongoDB:
MONGODB_URI=mongodb://localhost:27017/mydb
MONGODB_DATABASE=mydb

# SQL Server:
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_DATABASE=mydb
MSSQL_USER=sa
MSSQL_PASSWORD=secret
MSSQL_ENCRYPT=true
MSSQL_TRUST_CERT=false

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3434
LOCALHOST_ONLY=true

# ── Security (HTTP server only — not needed in MCP mode) ───────────────────────
# DLP_API_KEY=change-me-before-production

# ── Token Limits ───────────────────────────────────────────────────────────────
MAX_ROWS=20
DEFAULT_PREVIEW_ROWS=5
MAX_TEXT_LENGTH=200
